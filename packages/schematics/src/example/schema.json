{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "NgMcpUiExample",
  "title": "ng-mcp-ui example options",
  "type": "object",
  "properties": {
    "variant": {
      "type": "string",
      "description": "Which example app to scaffold.",
      "enum": ["demo", "minimal", "none"],
      "default": "demo"
    },
    "project": {
      "type": "string",
      "description": "The name of the project to target.",
      "$default": {
        "$source": "projectName"
      }
    }
  },
  "required": [],
  "additionalProperties": false
}
