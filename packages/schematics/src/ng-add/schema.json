{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "NgMcpUiNgAdd",
  "title": "ng-mcp-ui ng-add options",
  "type": "object",
  "properties": {
    "project": {
      "type": "string",
      "description": "The name of the project to target.",
      "$default": {
        "$source": "projectName"
      }
    },
    "ssr": {
      "type": "boolean",
      "description": "Ensure Angular SSR is set up (adds it if absent).",
      "default": true
    },
    "bundling": {
      "type": "string",
      "description": "How widget views are bundled.",
      "enum": ["lazy", "targets", "esbuild"],
      "default": "lazy"
    },
    "tunnelProvider": {
      "type": "string",
      "description": "Zero-auth dev tunnel provider.",
      "enum": ["cloudflare", "localtunnel", "untun"],
      "default": "cloudflare"
    },
    "example": {
      "type": "string",
      "description": "Which example app to scaffold.",
      "enum": ["demo", "minimal", "none"],
      "default": "demo"
    },
    "skipInstall": {
      "type": "boolean",
      "description": "Skip installing dependencies.",
      "default": false
    }
  },
  "required": [],
  "additionalProperties": false
}
