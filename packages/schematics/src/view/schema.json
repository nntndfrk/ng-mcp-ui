{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "NgMcpUiView",
  "title": "ng-mcp-ui view options",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the view.",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What name would you like to use for the view?"
    },
    "project": {
      "type": "string",
      "description": "The name of the project to target.",
      "$default": {
        "$source": "projectName"
      }
    },
    "withTool": {
      "type": "boolean",
      "description": "Also scaffold a paired MCP tool for this view (delegates to the `tool` generator).",
      "default": false
    }
  },
  "required": ["name"],
  "additionalProperties": false
}
